#!/bin/sh

# Run from tcc_27_layered_take2 after a seed script has produced canonical cc0.
set -eu
cd ..
cd artifacts

test -x cc0.exe
test -f cc0.o
test -f cc1_stubs.o

STATIC_BUILD=cc0_static_build
SELF_BUILD=cc0_static_self_build
rm -rf "$STATIC_BUILD" "$SELF_BUILD"
mkdir -p "$STATIC_BUILD" "$SELF_BUILD"

./cc0.exe -c ../tcc_27_layered_take2/linux_i386_syscalls.c \
    -o "$STATIC_BUILD/linux_i386_syscalls.o"
./cc0.exe -c ../tcc_27_layered_take2/cc0_static_syscalls.c \
    -o "$STATIC_BUILD/cc0_static_syscalls.o"
./cc0.exe -c ../tcc_27_layered_take2/cc0_static_start.c \
    -o "$STATIC_BUILD/cc0_static_start.o"
./cc0.exe -c ../tcc_27_layered_take2/cc0_libc.c \
    -o "$STATIC_BUILD/cc0_libc.o"
./cc0.exe "$STATIC_BUILD/cc0_static_start.o" \
    "$STATIC_BUILD/linux_i386_syscalls.o" \
    "$STATIC_BUILD/cc0_static_syscalls.o" cc0.o cc1_stubs.o \
    "$STATIC_BUILD/cc0_libc.o" -o cc0_static.exe
chmod +x cc0_static.exe

./cc0_static.exe -c ../tcc_27_layered_take2/linux_i386_syscalls.c \
    -o "$SELF_BUILD/linux_i386_syscalls.o"
./cc0_static.exe -c ../tcc_27_layered_take2/cc0_static_syscalls.c \
    -o "$SELF_BUILD/cc0_static_syscalls.o"
./cc0_static.exe -c ../tcc_27_layered_take2/cc0_static_start.c \
    -o "$SELF_BUILD/cc0_static_start.o"
./cc0_static.exe -c ../tcc_27_layered_take2/cc0_libc.c \
    -o "$SELF_BUILD/cc0_libc.o"
./cc0_static.exe -c ../tcc_27_layered_take2/cc0.c \
    -o "$SELF_BUILD/cc0.o"
./cc0_static.exe -c ../tcc_27_layered_take2/cc1_stubs.c \
    -o "$SELF_BUILD/cc1_stubs.o"

cmp "$STATIC_BUILD/linux_i386_syscalls.o" \
    "$SELF_BUILD/linux_i386_syscalls.o"
cmp "$STATIC_BUILD/cc0_static_syscalls.o" \
    "$SELF_BUILD/cc0_static_syscalls.o"
cmp "$STATIC_BUILD/cc0_static_start.o" \
    "$SELF_BUILD/cc0_static_start.o"
cmp "$STATIC_BUILD/cc0_libc.o" "$SELF_BUILD/cc0_libc.o"
cmp cc0.o "$SELF_BUILD/cc0.o"
cmp cc1_stubs.o "$SELF_BUILD/cc1_stubs.o"

./cc0_static.exe "$SELF_BUILD/cc0_static_start.o" \
    "$SELF_BUILD/linux_i386_syscalls.o" \
    "$SELF_BUILD/cc0_static_syscalls.o" "$SELF_BUILD/cc0.o" \
    "$SELF_BUILD/cc1_stubs.o" "$SELF_BUILD/cc0_libc.o" \
    -o cc0_static_self.exe
chmod +x cc0_static_self.exe
cmp cc0_static.exe cc0_static_self.exe

./cc0_static_self.exe -c ../tcc_27_layered_take2/cc0.c \
    -o "$SELF_BUILD/cc0_second.o"
cmp "$SELF_BUILD/cc0.o" "$SELF_BUILD/cc0_second.o"
printf 'cc0_static.exe: self rebuild is byte-identical\n'
