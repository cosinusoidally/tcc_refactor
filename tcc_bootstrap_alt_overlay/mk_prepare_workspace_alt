#!/bin/sh
set -eu

overlay_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
upstream_dir="$overlay_dir/../../tcc_bootstrap_alt"
workspace_root="$overlay_dir/_alt_work"
workspace_dir="$workspace_root/tcc_bootstrap_alt"

rm -rf "$workspace_root"
mkdir -p "$workspace_root"
cp -a "$upstream_dir" "$workspace_dir"
rm -rf "$workspace_dir/tcc_3" "$workspace_dir/tcc_3_orig" "$workspace_dir/tcc_24" "$workspace_dir/tcc_26"
if [ -d "$overlay_dir/tcc_10_alt" ]; then
    rm -rf "$workspace_dir/tcc_10"
    cp -a "$upstream_dir/tcc_10" "$workspace_dir/tcc_10"
    (
        cd "$overlay_dir/tcc_10_alt"
        tar cf - .
    ) | (
        cd "$workspace_dir/tcc_10"
        tar xf -
    )
fi
if [ -d "$overlay_dir/otccelf_alt" ]; then
    cp -a "$overlay_dir/otccelf_alt/." "$workspace_dir/otccelf/"
fi
chmod +x "$workspace_dir/otccelf/mk_loader"
if [ -f "$overlay_dir/after.kaem" ]; then
    cp -f "$overlay_dir/after.kaem" "$workspace_dir/after.kaem"
fi
if [ -d "$overlay_dir/phase1_support" ]; then
    rm -rf "$workspace_dir/phase1_support"
    cp -a "$overlay_dir/phase1_support" "$workspace_dir/phase1_support"
fi
rm -rf "$workspace_dir/tcc_23"
cp -a "$overlay_dir/tcc_23_alt" "$workspace_dir/tcc_23"
if [ -f "$overlay_dir/tcc_27_build_from_tcc23.kaem" ]; then
    cp -f "$overlay_dir/tcc_27_build_from_tcc23.kaem" "$workspace_dir/tcc_27/build_from_tcc23.kaem"
fi
if [ -f "$overlay_dir/tcc_27_run_27_static_from_tcc23.kaem" ]; then
    cp -f "$overlay_dir/tcc_27_run_27_static_from_tcc23.kaem" "$workspace_dir/tcc_27/run_27_static_from_tcc23.kaem"
fi
(
    cd "$workspace_dir"
    ./mk_really_clean >/dev/null 2>&1 || true
)

echo "$workspace_dir"
