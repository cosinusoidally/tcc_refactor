#!/bin/sh
set -eu

overlay_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
upstream_dir="$overlay_dir/../../tcc_bootstrap_alt"
workspace_root="$overlay_dir/_alt_work"
workspace_dir="$workspace_root/tcc_bootstrap_alt"

rm -rf "$workspace_root"
mkdir -p "$workspace_root"
cp -a "$upstream_dir" "$workspace_dir"
rm -rf "$workspace_dir/tcc_3"
cp -a "$overlay_dir/tcc_3_alt" "$workspace_dir/tcc_3"
rm -f "$workspace_dir/tcc_3/stdlib.h" \
      "$workspace_dir/tcc_3/stdio.h" \
      "$workspace_dir/tcc_3/string.h" \
      "$workspace_dir/tcc_3/math.h" \
      "$workspace_dir/tcc_3/unistd.h" \
      "$workspace_dir/tcc_3/malloc.h" \
      "$workspace_dir/tcc_3/dlfcn.h" \
      "$workspace_dir/tcc_3/features.h" \
      "$workspace_dir/tcc_3/errno.h" \
      "$workspace_dir/tcc_3/signal.h"
rm -rf "$workspace_dir/tcc_3/sys"
if [ -d "$overlay_dir/tcc_10_alt" ]; then
    cp -a "$overlay_dir/tcc_10_alt/." "$workspace_dir/tcc_10/"
fi
rm -rf "$workspace_dir/tcc_23"
cp -a "$overlay_dir/tcc_23_alt" "$workspace_dir/tcc_23"
(
    cd "$workspace_dir"
    ./mk_really_clean >/dev/null 2>&1 || true
)

echo "$workspace_dir"
