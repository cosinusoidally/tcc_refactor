#!/bin/sh
set -eu

overlay_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
upstream_dir="$overlay_dir/../../tcc_bootstrap_alt"
workspace_root="$overlay_dir/_alt_work"
workspace_dir="$workspace_root/tcc_bootstrap_alt"

rm -rf "$workspace_root"
mkdir -p "$workspace_root"
cp -a "$upstream_dir" "$workspace_dir"
rm -rf "$workspace_dir/tcc_23"
cp -a "$overlay_dir/tcc_23_alt" "$workspace_dir/tcc_23"
rm -rf "$workspace_dir/tcc_10"
mkdir -p "$workspace_dir/phase1_support"
cp -a "$overlay_dir/phase1_support/." "$workspace_dir/phase1_support/"
cp -a "$overlay_dir/tcc_js_build_phase1.kaem" "$workspace_dir/tcc_js/build_phase1.kaem"
cp -a "$overlay_dir/tcc_26_run_26_phase1.kaem" "$workspace_dir/tcc_26/run_26_phase1.kaem"
cp -a "$overlay_dir/phase1_after.kaem" "$workspace_dir/phase1_after.kaem"
cp -a "$overlay_dir/phase1_kaem.x86" "$workspace_dir/phase1_kaem.x86"
cp -a "$overlay_dir/phase1_probe_after.kaem" "$workspace_dir/phase1_probe_after.kaem"
cp -a "$overlay_dir/phase1_probe_kaem.x86" "$workspace_dir/phase1_probe_kaem.x86"
(
    cd "$workspace_dir"
    ./mk_really_clean >/dev/null 2>&1 || true
)

echo "$workspace_dir"
