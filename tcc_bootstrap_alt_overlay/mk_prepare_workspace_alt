#!/bin/sh
set -eu

overlay_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
upstream_dir="$overlay_dir/../../tcc_bootstrap_alt"
workspace_root="$overlay_dir/_alt_work"
workspace_dir="$workspace_root/tcc_bootstrap_alt"

rm -rf "$workspace_root"
mkdir -p "$workspace_root"
cp -a "$upstream_dir" "$workspace_dir"
rm -rf "$workspace_dir/tcc_3" "$workspace_dir/tcc_3_orig"
if [ -d "$overlay_dir/tcc_10_alt" ]; then
    cp -a "$overlay_dir/tcc_10_alt/." "$workspace_dir/tcc_10/"
fi
if [ -d "$overlay_dir/otccelf_alt" ]; then
    cp -a "$overlay_dir/otccelf_alt/." "$workspace_dir/otccelf/"
fi
chmod +x "$workspace_dir/otccelf/mk_loader"
rm -rf "$workspace_dir/tcc_23"
cp -a "$overlay_dir/tcc_23_alt" "$workspace_dir/tcc_23"
if [ -f "$overlay_dir/tcc_26_build.kaem" ]; then
    cp -f "$overlay_dir/tcc_26_build.kaem" "$workspace_dir/tcc_26/build.kaem"
fi
(
    cd "$workspace_dir"
    ./mk_really_clean >/dev/null 2>&1 || true
)

echo "$workspace_dir"
