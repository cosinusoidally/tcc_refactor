#!/bin/sh
set -eu

overlay_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root="$overlay_dir/.."
workspace_dir=$("$overlay_dir/mk_prepare_workspace_alt")

cp -f "$overlay_dir/tcc_10_alt/build_tcc2.kaem" \
    "$workspace_dir/tcc_10/build_tcc2.kaem"
cp -f "$overlay_dir/after_tcc10_tcc2.kaem" \
    "$workspace_dir/after_tcc10_tcc2.kaem"
cp -f "$overlay_dir/tcc10_alt_probe_tcc2_kaem.x86" \
    "$workspace_dir/tcc10_alt_probe_tcc2_kaem.x86"

(
    cd "$workspace_dir"
    ./mk_really_clean >/dev/null 2>&1 || true
    bash ./mk_seeds
)

(
    cd "$repo_root"
    /home/foo/src/gpt/tcc_refactor/scripts/run-i386.sh /bin/sh -c "cd '$workspace_dir' && ./tcc10_alt_probe_tcc2_kaem.x86"
)
