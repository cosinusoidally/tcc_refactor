#!/bin/sh
set -eu

overlay_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
workspace_dir=$("$overlay_dir/mk_prepare_workspace_tcc_23_alt")
host_dir="$workspace_dir/host_debug"
host_tcc23="$host_dir/tcc23_host.exe"

mkdir -p "$host_dir"

(
    cd "$workspace_dir"
    ./mk_really_clean >/dev/null 2>&1 || true
    bash ./mk_seeds
)

(
    cd "$workspace_dir/tcc_23"
    gcc -m32 -D__thread=__threadp tcc.c \
        -I ../woody/usr/include/ -I . -ldl \
        -o "$host_tcc23"
)

(
    cd "$workspace_dir/tcc_27"
    "$host_tcc23" -c -o i386_asm_lval_operand_min.o \
        "$overlay_dir/tcc_23_alt/tests/i386_asm_lval_operand_min.c"
    "$host_tcc23" -c -o function_proto_reloc_min.o \
        "$overlay_dir/tcc_23_alt/tests/function_proto_reloc_min.c"
    "$host_tcc23" -Iinclude -c -o tcc27_need_wint_type.o \
        "$overlay_dir/tcc_23_alt/tests/tcc27_need_wint_type.c"
    "$host_tcc23" -I../woody/usr/include/ -Iinclude -c -o tcc_from23_host.o \
        tcc.c
)

if ! objdump -dr "$workspace_dir/tcc_27/function_proto_reloc_min.o" \
    | grep -q 'R_386_PC32[[:space:]]*foo$'; then
    echo "function_proto_reloc_min.o does not relocate call sites to foo" >&2
    exit 1
fi

if ! objdump -dr "$workspace_dir/tcc_27/tcc_from23_host.o" \
    | sed -n '/<tcc_mallocz>/,/<tcc_realloc>/p' \
    | grep -q 'R_386_PC32[[:space:]]*tcc_malloc$'; then
    echo "tcc_from23_host.o does not relocate tcc_mallocz to tcc_malloc" >&2
    exit 1
fi
