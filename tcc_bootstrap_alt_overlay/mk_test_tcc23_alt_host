#!/bin/sh
set -eu

overlay_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
workspace_dir=$("$overlay_dir/mk_prepare_workspace_tcc_23_alt")
host_dir="$workspace_dir/host_debug"
host_tcc23="$host_dir/tcc23_host.exe"

mkdir -p "$host_dir"

(
    cd "$workspace_dir"
    ./mk_really_clean >/dev/null 2>&1 || true
    bash ./mk_seeds
)

(
    cd "$workspace_dir/tcc_23"
    gcc -m32 -D__thread=__threadp tcc.c \
        -I ../woody/usr/include/ -I . -ldl \
        -o "$host_tcc23"
)

(
    cd "$workspace_dir/tcc_27"
    "$host_tcc23" -c -o i386_asm_lval_operand_min.o \
        "$overlay_dir/tcc_23_alt/tests/i386_asm_lval_operand_min.c"
    "$host_tcc23" -c -o function_proto_reloc_min.o \
        "$overlay_dir/tcc_23_alt/tests/function_proto_reloc_min.c"
    "$host_tcc23" -c -o prefix_function_call_reloc_min.o \
        "$overlay_dir/tcc_23_alt/tests/prefix_function_call_reloc_min.c"
    "$host_tcc23" -c -o memcpy_prefix_reloc_min.o \
        "$overlay_dir/tcc_23_alt/tests/memcpy_prefix_reloc_min.c"
    "$host_tcc23" -I"$overlay_dir/tcc_23_alt/tests" -c -o one_source_proto_reloc_driver.o \
        "$overlay_dir/tcc_23_alt/tests/one_source_proto_reloc_driver.c"
    "$host_tcc23" -I../woody/usr/include/ -I. -Iinclude -c -o one_source_malloc_reloc_min.o \
        "$overlay_dir/tcc_23_alt/tests/one_source_malloc_reloc_min.c"
    "$host_tcc23" -c -o tcc27_malloc_cluster_min.o \
        "$overlay_dir/tcc_23_alt/tests/tcc27_malloc_cluster_min.c"
    "$host_tcc23" -Iinclude -c -o tcc27_need_wint_type.o \
        "$overlay_dir/tcc_23_alt/tests/tcc27_need_wint_type.c"
    "$host_tcc23" -I../woody/usr/include/ -Iinclude -c -o tcc_from23_host.o \
        tcc.c
)

if ! objdump -dr "$workspace_dir/tcc_27/function_proto_reloc_min.o" \
    | grep -q 'R_386_PC32[[:space:]]*foo$'; then
    echo "function_proto_reloc_min.o does not relocate call sites to foo" >&2
    exit 1
fi

if ! objdump -dr "$workspace_dir/tcc_27/prefix_function_call_reloc_min.o" \
    | sed -n '/<probe>/,/<alpha_long>/p' \
    | grep -q 'R_386_PC32[[:space:]]*alpha_long$'; then
    echo "prefix_function_call_reloc_min.o does not relocate probe to alpha_long" >&2
    exit 1
fi

if ! objdump -dr "$workspace_dir/tcc_27/memcpy_prefix_reloc_min.o" \
    | sed -n '/<probe>/,/<[^>]*>:/p' \
    | grep -q 'R_386_PC32[[:space:]]*memcpy$'; then
    echo "memcpy_prefix_reloc_min.o does not relocate probe to memcpy" >&2
    exit 1
fi

if ! objdump -dr "$workspace_dir/tcc_27/one_source_proto_reloc_driver.o" \
    | sed -n '/<bar>/,/<[^>]*>:/p' \
    | grep -q 'R_386_PC32[[:space:]]*foo$'; then
    echo "one_source_proto_reloc_driver.o does not relocate call sites to foo" >&2
    exit 1
fi

if ! objdump -dr "$workspace_dir/tcc_27/one_source_malloc_reloc_min.o" \
    | sed -n '/<tcc_mallocz>/,/<tcc_realloc>/p' \
    | grep -q 'R_386_PC32[[:space:]]*tcc_malloc$'; then
    echo "one_source_malloc_reloc_min.o does not relocate tcc_mallocz to tcc_malloc" >&2
    exit 1
fi

if ! objdump -dr "$workspace_dir/tcc_27/tcc27_malloc_cluster_min.o" \
    | sed -n '/<tcc_mallocz>/,/<tcc_realloc>/p' \
    | grep -q 'R_386_PC32[[:space:]]*tcc_malloc$'; then
    echo "tcc27_malloc_cluster_min.o does not relocate tcc_mallocz to tcc_malloc" >&2
    exit 1
fi

if ! objdump -dr "$workspace_dir/tcc_27/tcc_from23_host.o" \
    | sed -n '/<tcc_mallocz>/,/<tcc_realloc>/p' \
    | grep -q 'R_386_PC32[[:space:]]*tcc_malloc$'; then
    echo "tcc_from23_host.o does not relocate tcc_mallocz to tcc_malloc" >&2
    exit 1
fi
