#!/bin/sh
set -eu

overlay_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root="$overlay_dir/.."
workspace_dir=$("$overlay_dir/mk_prepare_workspace_alt")

cp -f "$overlay_dir/tcc_26_build_tcc23.kaem" \
    "$workspace_dir/tcc_26/build.kaem"

(
    cd "$workspace_dir"
    ./mk_really_clean >/dev/null 2>&1 || true
    bash ./mk_seeds
)

(
    cd "$repo_root"
    ./scripts/run-i386.sh /bin/sh -c \
        "cd '$workspace_dir' && ./x86/artifact/kaem-optional-seed"
)
