#!/bin/sh
set -eu

overlay_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root="$overlay_dir/.."
workspace_dir=$("$overlay_dir/mk_prepare_workspace_alt")

cp -f "$overlay_dir/tcc_10_alt/build_tcc2.kaem" "$workspace_dir/tcc_10/build.kaem"
cp -f "$overlay_dir/after_tcc23.kaem" "$workspace_dir/after.kaem"
cp -f "$overlay_dir/tcc_27_build_tcc23.kaem" "$workspace_dir/tcc_27/build.kaem"
cp -f "$overlay_dir/tcc_27_run_27_tcc23.kaem" "$workspace_dir/tcc_27/run_27.kaem"
cp -f "$overlay_dir/tcc_27_run_27_static_tcc23.kaem" "$workspace_dir/tcc_27/run_27_static.kaem"
cp -f "$overlay_dir/tcc_27_tcc23.h" "$workspace_dir/tcc_27/tcc_27_tcc23.h"
cp -f "$overlay_dir/tcc_27_libtcc_tcc23.h" "$workspace_dir/tcc_27/tcc_27_libtcc_tcc23.h"
cp -f "$overlay_dir/tcc_27_tcc23.c" "$workspace_dir/tcc_27/tcc_27_tcc23.c"
cp -f "$overlay_dir/tcc_27_tcctok_tcc23.h" "$workspace_dir/tcc_27/tcc_27_tcctok_tcc23.h"
cp -f "$overlay_dir/tcc_27_i386-tok_tcc23.h" "$workspace_dir/tcc_27/tcc_27_i386-tok_tcc23.h"
cp -f "$overlay_dir/tcc_27_i386-asm_tcc23.h" "$workspace_dir/tcc_27/tcc_27_i386-asm_tcc23.h"
cp -f "$overlay_dir/tcc_27_libtcc_tcc23.c" "$workspace_dir/tcc_27/tcc_27_libtcc_tcc23.c"
cp -f "$overlay_dir/tcc_27_tccpp_tcc23.c" "$workspace_dir/tcc_27/tcc_27_tccpp_tcc23.c"
cp -f "$overlay_dir/tcc_27_tccelf_tcc23.c" "$workspace_dir/tcc_27/tcc_27_tccelf_tcc23.c"
cp -f "$overlay_dir/tcc_27_tccgen_tcc23.c" "$workspace_dir/tcc_27/tcc_27_tccgen_tcc23.c"
cp -f "$overlay_dir/tcc_27_tccrun_tcc23.c" "$workspace_dir/tcc_27/tcc_27_tccrun_tcc23.c"
cp -f "$overlay_dir/tcc_27_i386-gen_tcc23.c" "$workspace_dir/tcc_27/tcc_27_i386-gen_tcc23.c"
cp -f "$overlay_dir/tcc_27_i386-asm_tcc23.c" "$workspace_dir/tcc_27/tcc_27_i386-asm_tcc23.c"
cp -f "$overlay_dir/tcc_27_tccasm_tcc23.c" "$workspace_dir/tcc_27/tcc_27_tccasm_tcc23.c"

(
    cd "$workspace_dir"
    ./mk_really_clean >/dev/null 2>&1 || true
    bash ./mk_seeds
)

(
    cd "$repo_root"
    ./scripts/run-i386.sh /bin/sh -c "cd '$workspace_dir' && ./x86/artifact/kaem-optional-seed"
)

(
    cd "$workspace_dir"
    sha256sum -c sum
)

"$overlay_dir/mk_verify_tcc_27_boot_static" "$workspace_dir"
