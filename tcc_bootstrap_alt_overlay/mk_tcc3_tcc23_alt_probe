#!/bin/sh
set -eu

overlay_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_root="$overlay_dir/.."
workspace_dir=$("$overlay_dir/mk_prepare_workspace_alt")

(
    cd "$workspace_dir/tcc_3"
    gcc -m32 -D__thread=__threadp tcc.c -I ../woody/usr/include/ -ldl -o a.out
)

(
    cd "$repo_root"
    ./scripts/run-i386.sh /bin/sh -c "cd '$workspace_dir/tcc_23' && ../tcc_3/a.out tcc.c -h"
)
