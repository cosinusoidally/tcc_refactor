#!/bin/sh
set -eu

overlay_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
workspace_dir=$("$overlay_dir/mk_prepare_workspace_alt")
workspace_tcc3="$workspace_dir/tcc_3"

copy_if_present() {
    src=$1
    dst=$2
    if [ -e "$src" ]; then
        mkdir -p "$(dirname "$dst")"
        cp -a "$src" "$dst"
    fi
}

copy_if_present "$overlay_dir/tcc_3_alt/stdlib.h" "$workspace_tcc3/stdlib.h"
copy_if_present "$overlay_dir/tcc_3_alt/stdio.h" "$workspace_tcc3/stdio.h"
copy_if_present "$overlay_dir/tcc_3_alt/string.h" "$workspace_tcc3/string.h"
copy_if_present "$overlay_dir/tcc_3_alt/math.h" "$workspace_tcc3/math.h"
copy_if_present "$overlay_dir/tcc_3_alt/unistd.h" "$workspace_tcc3/unistd.h"
copy_if_present "$overlay_dir/tcc_3_alt/fcntl.h" "$workspace_tcc3/fcntl.h"
copy_if_present "$overlay_dir/tcc_3_alt/malloc.h" "$workspace_tcc3/malloc.h"
copy_if_present "$overlay_dir/tcc_3_alt/dlfcn.h" "$workspace_tcc3/dlfcn.h"
copy_if_present "$overlay_dir/tcc_3_alt/features.h" "$workspace_tcc3/features.h"
copy_if_present "$overlay_dir/tcc_3_alt/errno.h" "$workspace_tcc3/errno.h"
copy_if_present "$overlay_dir/tcc_3_alt/signal.h" "$workspace_tcc3/signal.h"
copy_if_present "$overlay_dir/tcc_3_alt/setjmp.h" "$workspace_tcc3/setjmp.h"
copy_if_present "$overlay_dir/tcc_3_alt/time.h" "$workspace_tcc3/time.h"
copy_if_present "$overlay_dir/tcc_3_alt/sys/mman.h" "$workspace_tcc3/sys/mman.h"
copy_if_present "$overlay_dir/tcc_3_alt/sys/time.h" "$workspace_tcc3/sys/time.h"
copy_if_present "$overlay_dir/tcc_3_alt/sys/types.h" "$workspace_tcc3/sys/types.h"
copy_if_present "$overlay_dir/tcc_3_alt/sys/ucontext.h" "$workspace_tcc3/sys/ucontext.h"
copy_if_present "$overlay_dir/tcc_3_alt/elf.h" "$workspace_dir/tcc_10/elf.h"
copy_if_present "$overlay_dir/tcc_10_libc_boot_tcc3_getc.c" \
    "$workspace_dir/tcc_10/libc_boot_tcc3_getc.c"

echo "$workspace_dir"
