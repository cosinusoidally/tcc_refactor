#!/bin/sh

# Run from tcc_27_layered_take3 after mk_cc1_js. Every compiler object below
# is produced by the preceding layer; no native C compiler is part of the path.
set -eu
cd ..
cd artifacts

test -x cc1.exe

# Only runtime DSOs are required.  In particular, a minbase installation does
# not need libc development files, GCC startup objects, or static libgcc.
RUNTIME_LIBDIR=/lib/i386-linux-gnu
if test ! -f "$RUNTIME_LIBDIR/libc.so.6"; then
    RUNTIME_LIBDIR=/usr/lib/i386-linux-gnu
fi
HOST_LIBC=$RUNTIME_LIBDIR/libc.so.6
HOST_LIBM=$RUNTIME_LIBDIR/libm.so.6
test -f "$HOST_LIBC" -a -f "$HOST_LIBM"

./cc1.exe -c ../tcc_27_layered_take3/cc1.c -o cc1_self.o
cmp cc1.o cc1_self.o
./cc1.exe -c ../tcc_27_layered_take3/crt1.c -o crt1.o
cat ../tcc_27_layered_take3/cc2.c \
    ../tcc_27_layered_take3/cc2_boot_storage.c > cc2_boot_combined.c
./cc1.exe -c cc2_boot_combined.c -o cc2_boot_combined.o
./cc1.exe -c ../tcc_27_layered_take3/cc2.c -o cc2.o
./cc1.exe -c ../tcc_27_layered_take3/cc2_backend_stubs.c \
    -o cc2_backend_stubs.o
./cc1.exe cc2_boot_combined.o cc2_backend_stubs.o \
    -o cc2_boot.exe

# The bootstrap backend is sufficient for cc2 to compile its typed bridge and
# immutable i386 tables.  Re-linking with those objects yields the full cc2.
./cc2_boot.exe \
    -nostdinc \
    -I ../tcc_27_layered_take3/bootstrap_include/ \
    -I ../tcc_27_layered_take3/include -I ../tcc_27_layered_take3/ \
    -c ../tcc_27_layered_take3/tcc_unified.c -U__linux__ -o tcc_rest.o
./cc2_boot.exe -nostdinc -c ../tcc_27_layered_take3/cc2_runtime.c \
    -o cc2_runtime_boot.o
# The transitional executable still uses the lower linker, which owns the
# base-case ELF entry adapter.  The resulting full cc2 performs the final link.
./cc1.exe cc2.o tcc_rest.o cc2_runtime_boot.o -o cc2_transition.exe
chmod +x cc2_transition.exe

# Use identical working-directory layouts so source and object names cannot
# hide a non-reproducible self-host. cc1 contributes only the transition tool;
# none of its object code enters either canonical generation.
build_cc2_generation()
{
    directory=$1
    compiler=$2
    rm -rf "$directory"
    mkdir -p "$directory"
    (
        cd "$directory"
        "$compiler" -nostdinc \
            -c ../../tcc_27_layered_take3/linux_i386_start.c \
            -o linux_i386_start.o
        "$compiler" -nostdinc -c ../../tcc_27_layered_take3/cc2_start.c \
            -o cc2_start.o
        "$compiler" -nostdinc -c ../../tcc_27_layered_take3/prims.c \
            -o prims.o
        "$compiler" -nostdinc -Dfunction=int -Dvar=int \
            -c ../../tcc_27_layered_take3/cc2.c -o cc2.o
        "$compiler" -nostdinc \
            -c ../../tcc_27_layered_take3/cc2_runtime.c -o cc2_runtime.o
        "$compiler" -nostdinc \
            -I ../../../tcc_bootstrap_alt/woody/usr/include/ \
            -I ../../tcc_27_layered_take3/include \
            -I ../../tcc_27_layered_take3/ \
            -c ../../tcc_27_layered_take3/tcc_unified.c -U__linux__ \
            -o tcc_rest.o
        "$compiler" -nostdlib linux_i386_start.o cc2_start.o prims.o \
            cc2.o tcc_rest.o cc2_runtime.o "$HOST_LIBC" "$HOST_LIBM" \
            -o cc2.exe
        chmod +x cc2.exe
    )
}

build_cc2_generation cc2_selfhost_1 ../cc2_transition.exe
build_cc2_generation cc2_selfhost_2 ../cc2_selfhost_1/cc2.exe
for object in linux_i386_start.o cc2_start.o prims.o cc2.o cc2_runtime.o \
    tcc_rest.o cc2.exe
do
    cmp "cc2_selfhost_1/$object" "cc2_selfhost_2/$object"
done

# Publish only generation-two products. The layered compiler is precisely the
# independently linked, fully self-hosted cc2 compiler.
cp cc2_selfhost_2/cc2_start.o cc2_start.o
cp cc2_selfhost_2/linux_i386_start.o linux_i386_start.o
cp cc2_selfhost_2/prims.o prims_final.o
cp cc2_selfhost_2/cc2.o cc2_final.o
cp cc2_selfhost_2/cc2_runtime.o cc2_runtime_final.o
cp cc2_selfhost_2/tcc_rest.o tcc_rest_final.o
cp cc2_selfhost_2/cc2.exe cc2.exe
cp cc2_selfhost_2/cc2.exe tcc_layered.exe

# Build the stock TCC 0.9.27 compatibility artifacts and verify their fixed
# reference hashes.  The source is stock tcc_27; the compiler is layered TCC.
ln -sf ../tcc_27/libc_boot4.c libc_boot4.c
ln -sf ../tcc_27/libc_static.c libc_static.c
ln -sf ../tcc_27/tcc.c tcc.c
mkdir -p lib
ln -sf ../../tcc_27/lib/libtcc1.c lib/libtcc1.c

./tcc_layered.exe \
    -nostdinc \
    -I ../../tcc_bootstrap_alt/woody/usr/include/ \
    -I ../tcc_27/include -I ../tcc_27/ \
    -c tcc.c -U__linux__ -DONE_SOURCE -o tcc.o
./tcc_layered.exe -nostdinc -c ./lib/libtcc1.c -o libtcc1.o
./tcc_layered.exe -nostdinc -c libc_boot4.c -o libc_boot4.o
./tcc_layered.exe -nostdinc -c libc_static.c -o libc_static.o
./tcc_layered.exe -nostdlib -static libc_static.o libc_boot4.o libtcc1.o \
    tcc.o -o tcc_27_boot_static.exe

cd ..
sha256sum -c sums_tcc_27
