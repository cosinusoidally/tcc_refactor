#!/bin/sh

# Run from tcc_27_layered_take3 after a seed has built cc0_static.exe. This is
# deliberately separate from the dynamic chain so later layers can become
# static independently without coupling the two bootstrap graphs.
set -eu
cd ..
cd artifacts

test -x cc0_static.exe

# cc2 and the upper layers are still dynamically linked for now, so this path
# retains the versioned runtime DSOs used by the existing bootstrap.
RUNTIME_LIBDIR=/lib/i386-linux-gnu
if test ! -f "$RUNTIME_LIBDIR/libc.so.6"; then
    RUNTIME_LIBDIR=/usr/lib/i386-linux-gnu
fi
HOST_LIBC=$RUNTIME_LIBDIR/libc.so.6
HOST_LIBM=$RUNTIME_LIBDIR/libm.so.6
test -f "$HOST_LIBC" -a -f "$HOST_LIBM"

./cc0_static.exe -c ../tcc_27_layered_take3/cc0.c -o cc0.o
./cc0_static.exe -c ../tcc_27_layered_take3/cc1.c -o cc1.o
./cc0_static.exe -c ../tcc_27_layered_take3/cc2_stubs.c -o cc2_stubs.o
./cc0_static.exe -c ../tcc_27_layered_take3/crt1.c -o crt1.o
./cc0_static.exe -c ../tcc_27_layered_take3/linux_i386_syscalls.c \
    -o linux_i386_syscalls_static.o
./cc0_static.exe -c ../tcc_27_layered_take3/cc0_static_syscalls.c \
    -o cc0_static_syscalls_static.o
./cc0_static.exe -c ../tcc_27_layered_take3/cc0_static_start.c \
    -o cc0_static_start_static.o
./cc0_static.exe -c ../tcc_27_layered_take3/cc0_libc.c \
    -o cc0_libc_static.o
./cc0_static.exe cc0_static_start_static.o \
    linux_i386_syscalls_static.o cc0_static_syscalls_static.o \
    cc0.o cc1.o cc2_stubs.o cc0_libc_static.o -o cc1_static.exe
chmod +x cc1_static.exe

./cc1_static.exe -c ../tcc_27_layered_take3/cc2_boot_unified.c \
    -o cc2_boot_unified.o
./cc1_static.exe -c ../tcc_27_layered_take3/cc2.c -o cc2.o
./cc1_static.exe -c ../tcc_27_layered_take3/cc2_backend_stubs.c \
    -o cc2_backend_stubs.o
./cc1_static.exe cc0.o cc1.o cc2_boot_unified.o cc2_backend_stubs.o \
    -o cc2_boot.exe

# The bootstrap backend is sufficient for cc2 to compile its typed bridge and
# immutable i386 tables. Re-linking with those objects yields the full cc2.
./cc2_boot.exe \
    -nostdinc \
    -I ../tcc_27_layered_take3/bootstrap_include/ \
    -I ../tcc_27_layered_take3/include -I ../tcc_27_layered_take3/ \
    -c ../tcc_27_layered_take3/tcc_unified.c -U__linux__ -o tcc_rest.o
./cc2_boot.exe -nostdinc -c ../tcc_27_layered_take3/cc2_runtime.c \
    -o cc2_runtime_boot.o
# The transitional executable still uses the static cc0 lower linker. The
# resulting full cc2 performs the final dynamically linked compiler link.
./cc0_static.exe cc0.o cc1.o cc2.o tcc_rest.o cc2_runtime_boot.o \
    -o cc2.exe
chmod +x cc2.exe

# cc2 is the full TCC layer. It rebuilds every final compiler-owned object.
./cc2.exe -nostdinc -c ../tcc_27_layered_take3/prims.c -o prims_final.o
./cc2.exe -nostdinc -std=cc0 -c ../tcc_27_layered_take3/cc0.c \
    -o cc0_final.o
./cc2.exe -nostdinc -std=cc0 -c ../tcc_27_layered_take3/cc1.c \
    -o cc1_final.o
./cc2.exe -nostdinc -std=cc0 -c ../tcc_27_layered_take3/cc2.c \
    -o cc2_final.o
./cc2.exe -nostdinc -c ../tcc_27_layered_take3/cc2_runtime.c \
    -o cc2_runtime_final.o
./cc2.exe \
    -nostdinc \
    -I ../../tcc_bootstrap_alt/woody/usr/include/ \
    -I ../tcc_27_layered_take3/include -I ../tcc_27_layered_take3/ \
    -c ../tcc_27_layered_take3/tcc_unified.c -U__linux__ \
    -o tcc_rest_final.o
./cc2.exe -nostdlib crt1.o \
    prims_final.o cc0_final.o cc1_final.o cc2_final.o tcc_rest_final.o \
    cc2_runtime_final.o \
    "$HOST_LIBC" "$HOST_LIBM" \
    -o tcc_layered.exe
chmod +x tcc_layered.exe

# Build the stock TCC 0.9.27 compatibility artifacts and verify their fixed
# reference hashes. The source is stock tcc_27; the compiler is layered TCC.
ln -sf ../tcc_27/libc_boot4.c libc_boot4.c
ln -sf ../tcc_27/libc_static.c libc_static.c
ln -sf ../tcc_27/tcc.c tcc.c
mkdir -p lib
ln -sf ../../tcc_27/lib/libtcc1.c lib/libtcc1.c

./tcc_layered.exe \
    -nostdinc \
    -I ../../tcc_bootstrap_alt/woody/usr/include/ \
    -I ../tcc_27/include -I ../tcc_27/ \
    -c tcc.c -U__linux__ -DONE_SOURCE -o tcc.o
./tcc_layered.exe -nostdinc -c ./lib/libtcc1.c -o libtcc1.o
./tcc_layered.exe -nostdinc -c libc_boot4.c -o libc_boot4.o
./tcc_layered.exe -nostdinc -c libc_static.c -o libc_static.o
./tcc_layered.exe -nostdlib -static libc_static.o libc_boot4.o libtcc1.o \
    tcc.o -o tcc_27_boot_static.exe

cd ..
sha256sum -c sums_tcc_27
