#!/bin/sh

# Run from tcc_27_layered_take3.  mawkcc builds a disposable cc0 seed; that
# seed then emits the canonical objects and executable through cc0 itself.
set -eu
cd ..
mkdir -p artifacts

cat tcc_27_layered_take3/cc0.c \
    tcc_27_layered_take3/cc1_stubs.c \
    tcc_27_layered_take3/cc0_mawkcc_compat.c \
    > artifacts/cc0_mawkcc.c

../ai_experiments/mawkcc/artifacts/mawkcc.self.exe \
    artifacts/cc0_mawkcc.c -o artifacts/cc0_mawkcc.exe
chmod +x artifacts/cc0_mawkcc.exe

cd artifacts
./cc0_mawkcc.exe -c ../tcc_27_layered_take3/cc0.c -o cc0.o
./cc0_mawkcc.exe -c ../tcc_27_layered_take3/cc1_stubs.c \
    -o cc1_stubs.o
./cc0_mawkcc.exe -c ../tcc_27_layered_take3/linux_i386_syscalls.c \
    -o linux_i386_syscalls_mawkcc.o
./cc0_mawkcc.exe -c ../tcc_27_layered_take3/cc0_static_syscalls.c \
    -o cc0_static_syscalls_mawkcc.o
./cc0_mawkcc.exe -c ../tcc_27_layered_take3/cc0_static_start.c \
    -o cc0_static_start_mawkcc.o
./cc0_mawkcc.exe -c ../tcc_27_layered_take3/cc0_libc.c \
    -o cc0_libc_mawkcc.o
./cc0_mawkcc.exe cc0_static_start_mawkcc.o \
    linux_i386_syscalls_mawkcc.o cc0_static_syscalls_mawkcc.o \
    cc0.o cc1_stubs.o cc0_libc_mawkcc.o -o cc0_static.exe
chmod +x cc0_static.exe
./cc0_mawkcc.exe cc0.o cc1_stubs.o -o cc0.exe
