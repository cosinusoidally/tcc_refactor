#!/bin/sh

# Build every compiler layer as a static i386 executable. The only required
# seed is artifacts/cc1_static.exe; no host compiler or host runtime is used.
set -eux

cd ..
test -x artifacts/cc1_static.exe

BUILD=artifacts/tcc_layered_static
rm -rf "$BUILD"
mkdir -p "$BUILD"
cd "$BUILD"

CC1=../cc1_static.exe
SOURCE=../../tcc_27_layered_take3

# Static cc1 rebuilds itself and the runtime before advancing to cc2.
"$CC1" -c "$SOURCE/cc1.c" -o cc1.o
"$CC1" -c "$SOURCE/cc2_stubs.c" -o cc2_stubs.o
"$CC1" -c "$SOURCE/linux_i386_syscalls.c" -o linux_i386_syscalls.o
"$CC1" -c "$SOURCE/cc0_static_syscalls.c" -o cc0_static_syscalls.o
"$CC1" -c "$SOURCE/cc0_static_start.c" -o cc0_static_start.o
"$CC1" -c "$SOURCE/cc1_libc.c" -o cc1_libc.o
"$CC1" -c "$SOURCE/cc1_libc_asm.c" -o cc1_libc_asm.o
"$CC1" cc0_static_start.o linux_i386_syscalls.o \
    cc0_static_syscalls.o cc1.o cc2_stubs.o cc1_libc.o cc1_libc_asm.o \
    -o cc1_static.exe
chmod +x cc1_static.exe
cp cc1_static.exe ../cc1_static.exe

# Static cc1 adds the layer-one libc and constructs the temporary static cc2.
./cc1_static.exe -c "$SOURCE/cc1_static_start.c" -o cc1_static_start.o
./cc1_static.exe -c "$SOURCE/cc2_float_libc_stubs.c" \
    -o cc2_float_libc_stubs.o
./cc1_static.exe -c "$SOURCE/cc2.c" -o cc2.o
cat "$SOURCE/cc2.c" "$SOURCE/cc2_boot_storage.c" > cc2_boot_combined.c
./cc1_static.exe -c cc2_boot_combined.c -o cc2_boot_combined.o
./cc1_static.exe -c "$SOURCE/cc2_backend_stubs.c" -o cc2_backend_stubs.o
./cc1_static.exe cc1_static_start.o linux_i386_syscalls.o \
    cc0_static_syscalls.o cc2_boot_combined.o \
    cc2_backend_stubs.o cc1_libc.o cc1_libc_asm.o \
    cc2_float_libc_stubs.o \
    -o cc2_boot_static.exe
chmod +x cc2_boot_static.exe

# The temporary cc2 can compile the typed TCC bridge and typed arithmetic
# runtime. Static cc1 then links the first complete static cc2 compiler.
./cc2_boot_static.exe -nostdinc \
    -I "$SOURCE/bootstrap_include" -I "$SOURCE/include" -I "$SOURCE" \
    -c "$SOURCE/tcc_unified.c" -U__linux__ -o tcc_rest_boot.o
./cc2_boot_static.exe -nostdinc -c "$SOURCE/cc2_runtime.c" \
    -o cc2_runtime_boot.o
./cc1_static.exe cc1_static_start.o linux_i386_syscalls.o \
    cc0_static_syscalls.o cc2.o tcc_rest_boot.o \
    cc2_runtime_boot.o cc1_libc.o cc1_libc_asm.o \
    cc2_float_libc_stubs.o -o cc2_static_boot.exe
chmod +x cc2_static_boot.exe

# Provisional full cc2 builds the floating libc, then relinks itself without
# the scalar float stubs before compiling sources containing decimal literals.
./cc2_static_boot.exe -nostdinc -c "$SOURCE/cc2_libc.c" \
    -o cc2_libc_boot.o
./cc1_static.exe cc1_static_start.o linux_i386_syscalls.o \
    cc0_static_syscalls.o cc2.o tcc_rest_boot.o \
    cc2_runtime_boot.o cc1_libc.o cc1_libc_asm.o \
    cc2_libc_boot.o -o cc2_static_transition.exe
chmod +x cc2_static_transition.exe

# Rebuild every object linked into static cc2. The transition executable is a
# tool only; neither it nor any cc1-built object enters a canonical generation.
build_static_cc2_generation()
{
    directory=$1
    compiler=$2
    rm -rf "$directory"
    mkdir -p "$directory"
    (
        cd "$directory"
        stage_source=../../tcc_27_layered_take3
        "$compiler" -nostdinc -c "$stage_source/linux_i386_start.c" \
            -o linux_i386_start.o
        "$compiler" -nostdinc -c "$stage_source/cc2_static_start.c" \
            -o cc2_static_start.o
        "$compiler" -nostdinc -Dfunction=int -Dvar=int \
            -c "$stage_source/linux_i386_syscalls.c" \
            -o linux_i386_syscalls.o
        "$compiler" -nostdinc -Dfunction=int -Dvar=int \
            -c "$stage_source/cc0_static_syscalls.c" \
            -o cc0_static_syscalls.o
        "$compiler" -nostdinc -c "$stage_source/prims.c" -o prims.o
        "$compiler" -nostdinc -Dfunction=int -Dvar=int \
            -c "$stage_source/cc2.c" -o cc2.o
        "$compiler" -nostdinc -c "$stage_source/cc2_runtime.c" \
            -o cc2_runtime.o
        "$compiler" -nostdinc \
            -I ../../../tcc_bootstrap_alt/woody/usr/include \
            -I "$stage_source/include" -I "$stage_source" \
            -c "$stage_source/tcc_unified.c" -U__linux__ -o tcc_rest.o
        "$compiler" -nostdinc -Dfunction=int -Dvar=int \
            -c "$stage_source/cc1_libc.c" -o cc1_libc.o
        "$compiler" -nostdinc -Dfunction=int -Dvar=int \
            -c "$stage_source/cc1_libc_asm.c" -o cc1_libc_asm.o
        "$compiler" -nostdinc -c "$stage_source/cc2_libc.c" \
            -o cc2_libc.o
        "$compiler" -nostdlib -static linux_i386_start.o \
            cc2_static_start.o linux_i386_syscalls.o \
            cc0_static_syscalls.o prims.o cc2.o tcc_rest.o cc2_runtime.o \
            cc1_libc.o cc1_libc_asm.o cc2_libc.o \
            -o cc2_static.exe
        chmod +x cc2_static.exe
    )
}

build_static_cc2_generation ../cc2_static_selfhost_1 \
    ../tcc_layered_static/cc2_static_transition.exe
build_static_cc2_generation ../cc2_static_selfhost_2 \
    ../cc2_static_selfhost_1/cc2_static.exe
for object in linux_i386_start.o cc2_static_start.o \
    linux_i386_syscalls.o cc0_static_syscalls.o prims.o cc2.o \
    cc2_runtime.o tcc_rest.o cc1_libc.o cc1_libc_asm.o cc2_libc.o \
    cc2_static.exe
do
    cmp "../cc2_static_selfhost_1/$object" \
        "../cc2_static_selfhost_2/$object"
done

cp ../cc2_static_selfhost_2/cc2_static.exe ../cc2_static.exe
cp ../cc2_static_selfhost_2/cc2_static.exe ../tcc_layered_static.exe

# Use canonical artifact-root names because TCC retains input names in objects.
cd ..
ln -sf ../tcc_27/libc_boot4.c libc_boot4.c
ln -sf ../tcc_27/libc_static.c libc_static.c
ln -sf ../tcc_27/tcc.c tcc.c
mkdir -p lib
ln -sf ../../tcc_27/lib/libtcc1.c lib/libtcc1.c

# The fully static layered TCC builds the stock 0.9.27 compatibility outputs.
TCC=./tcc_layered_static.exe
"$TCC" -nostdinc \
    -I ../../tcc_bootstrap_alt/woody/usr/include \
    -I ../tcc_27/include -I ../tcc_27 \
    -c tcc.c -U__linux__ -DONE_SOURCE -o tcc.o
"$TCC" -nostdinc -c ./lib/libtcc1.c -o libtcc1.o
"$TCC" -nostdinc -c libc_boot4.c -o libc_boot4.o
"$TCC" -nostdinc -c libc_static.c -o libc_static.o
"$TCC" -nostdlib -static libc_static.o libc_boot4.o libtcc1.o tcc.o \
    -o tcc_27_boot_static.exe

cd ..
sha256sum -c sums_tcc_27
