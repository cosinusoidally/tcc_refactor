#!/bin/sh

# Direct mawkcc seed path. This intentionally contains no cc1 source. Current
# mawkcc still needs dialect/relocation work before this large input completes.
set -eu
cd ..
mkdir -p artifacts

RUNTIME_LIBDIR=/lib/i386-linux-gnu
if test ! -f "$RUNTIME_LIBDIR/libc.so.6"; then
    RUNTIME_LIBDIR=/usr/lib/i386-linux-gnu
fi
test -f "$RUNTIME_LIBDIR/libc.so.6"
test -f "$RUNTIME_LIBDIR/libm.so.6"
ln -sf "$RUNTIME_LIBDIR/libc.so.6" artifacts/cc2_mawkcc_libc.so
ln -sf "$RUNTIME_LIBDIR/libm.so.6" artifacts/cc2_mawkcc_libm.so

cat tcc_27_layered_take3/cc2.c \
    tcc_27_layered_take3/cc2_boot_storage.c \
    tcc_27_layered_take3/cc2_backend_stubs.c \
    tcc_27_layered_take3/cc0_mawkcc_compat.c \
    > artifacts/cc2_mawkcc.c

../ai_experiments/mawkcc/artifacts/mawkcc.self.exe \
    artifacts/cc2_mawkcc.c -o artifacts/cc2_mawkcc_runner.exe
chmod +x artifacts/cc2_mawkcc_runner.exe

cd artifacts
RUNNER=./cc2_mawkcc_runner.exe
SOURCE=../tcc_27_layered_take3
"$RUNNER" -nostdinc -c "$SOURCE/linux_i386_start.c" \
    -o cc2_mawkcc_linux_i386_start.o
"$RUNNER" -nostdinc -c "$SOURCE/cc2_start.c" -o cc2_mawkcc_start.o
"$RUNNER" -nostdinc -c "$SOURCE/prims.c" -o cc2_mawkcc_prims.o
"$RUNNER" -nostdinc -Dfunction=int -Dvar=int -c "$SOURCE/cc2.c" \
    -o cc2_mawkcc.o
"$RUNNER" -nostdinc -c "$SOURCE/cc2_runtime.c" -o cc2_mawkcc_runtime.o
"$RUNNER" -nostdinc -I ../../tcc_bootstrap_alt/woody/usr/include \
    -I "$SOURCE/include" -I "$SOURCE" -U__linux__ \
    -c "$SOURCE/tcc_unified.c" -o cc2_mawkcc_tcc_rest.o
"$RUNNER" -nostdlib cc2_mawkcc_linux_i386_start.o cc2_mawkcc_start.o \
    cc2_mawkcc_prims.o cc2_mawkcc.o cc2_mawkcc_tcc_rest.o \
    cc2_mawkcc_runtime.o cc2_mawkcc_libc.so cc2_mawkcc_libm.so \
    -o cc2_mawkcc_seed.exe
chmod +x cc2_mawkcc_seed.exe
cd ..

CC2_SEED=artifacts/cc2_mawkcc_seed.exe \
    tcc_27_layered_take3/mk_cc2_from_seed
