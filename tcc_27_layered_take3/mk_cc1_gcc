#!/bin/sh

# Run from tcc_27_layered_take3. GCC builds only a disposable i386 cc1 seed;
# that seed emits the same canonical objects as the JS and mawkcc paths.
set -eux
cd ..
mkdir -p artifacts

SOURCE=tcc_27_layered_take3
gcc -m32 -O0 -nostdinc -std=gnu89 -Dfunction=int -Dvar=int \
    -c "$SOURCE/prims.c" -o artifacts/prims_gcc_seed.o
gcc -m32 -O0 -nostdinc -std=gnu89 -Dfunction=int -Dvar=int \
    -c "$SOURCE/cc1.c" -o artifacts/cc1_gcc_seed.o
gcc -m32 -O0 -nostdinc -std=gnu89 -Dfunction=int -Dvar=int \
    -c "$SOURCE/cc2_stubs.c" -o artifacts/cc2_stubs_gcc_seed.o
gcc -m32 artifacts/prims_gcc_seed.o artifacts/cc1_gcc_seed.o \
    artifacts/cc2_stubs_gcc_seed.o -o artifacts/cc1_gcc.exe

cd artifacts
./cc1_gcc.exe -c ../tcc_27_layered_take3/cc1.c -o cc1.o
./cc1_gcc.exe -c ../tcc_27_layered_take3/cc2_stubs.c -o cc2_stubs.o
./cc1_gcc.exe -c ../tcc_27_layered_take3/linux_i386_syscalls.c \
    -o linux_i386_syscalls_gcc.o
./cc1_gcc.exe -c ../tcc_27_layered_take3/cc0_static_syscalls.c \
    -o cc0_static_syscalls_gcc.o
./cc1_gcc.exe -c ../tcc_27_layered_take3/cc0_static_start.c \
    -o cc0_static_start_gcc.o
./cc1_gcc.exe -c ../tcc_27_layered_take3/cc1_libc.c -o cc1_libc_gcc.o
./cc1_gcc.exe -c ../tcc_27_layered_take3/cc1_libc_asm.c \
    -o cc1_libc_asm_gcc.o
./cc1_gcc.exe cc0_static_start_gcc.o linux_i386_syscalls_gcc.o \
    cc0_static_syscalls_gcc.o cc1.o cc2_stubs.o cc1_libc_gcc.o \
    cc1_libc_asm_gcc.o \
    -o cc1_static.exe
chmod +x cc1_static.exe
./cc1_gcc.exe cc1.o cc2_stubs.o -o cc1.exe
chmod +x cc1.exe
