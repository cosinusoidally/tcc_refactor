#!/bin/sh

# Run from tcc_27_layered_take3. mawkcc builds a disposable cc1 seed; that
# seed then emits the canonical objects and executable through cc1 itself.
set -eu
cd ..
mkdir -p artifacts

cat tcc_27_layered_take3/cc1.c \
    tcc_27_layered_take3/cc2_stubs.c \
    tcc_27_layered_take3/cc0_mawkcc_compat.c \
    > artifacts/cc1_mawkcc.c

../ai_experiments/mawkcc/artifacts/mawkcc.self.exe \
    artifacts/cc1_mawkcc.c -o artifacts/cc1_mawkcc.exe
chmod +x artifacts/cc1_mawkcc.exe

cd artifacts
./cc1_mawkcc.exe -c ../tcc_27_layered_take3/cc1.c -o cc1.o
./cc1_mawkcc.exe -c ../tcc_27_layered_take3/cc2_stubs.c -o cc2_stubs.o
./cc1_mawkcc.exe -c ../tcc_27_layered_take3/linux_i386_syscalls.c \
    -o linux_i386_syscalls_mawkcc.o
./cc1_mawkcc.exe -c ../tcc_27_layered_take3/cc0_static_syscalls.c \
    -o cc0_static_syscalls_mawkcc.o
./cc1_mawkcc.exe -c ../tcc_27_layered_take3/cc0_static_start.c \
    -o cc0_static_start_mawkcc.o
./cc1_mawkcc.exe -c ../tcc_27_layered_take3/cc0_libc.c \
    -o cc0_libc_mawkcc.o
./cc1_mawkcc.exe cc0_static_start_mawkcc.o \
    linux_i386_syscalls_mawkcc.o cc0_static_syscalls_mawkcc.o \
    cc1.o cc2_stubs.o cc0_libc_mawkcc.o -o cc1_static.exe
chmod +x cc1_static.exe
./cc1_mawkcc.exe cc1.o cc2_stubs.o -o cc1.exe
